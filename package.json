{
  "name": "workplace-resilience-quiz",
  "version": "1.3.0",
  "private": true,
  "type": "module",
  "description": "職場韌力角色心理測驗靜態網站",
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "test:e2e": "playwright test",
    "validate": "node scripts/validate-site.mjs",
    "build": "node scripts/build.mjs",
    "check": "npm test && npm run validate && npm run build",
    "serve": "python3 -m http.server 4173",
    "serve:dist": "python3 -m http.server 4173 --directory dist"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1"
  },
  "engines": {
    "node": ">=20"
  }
}
